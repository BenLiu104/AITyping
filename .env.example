# ─── 範本：複製成 .env 再填真值。.env 已被 gitignore，切勿提交 ───

# Gemini API（真 key 只放在後端的 .env，前端永不接觸）
GEMINI_API_KEY=your_gemini_api_key_here

# Model 名（集中管理；上線前對官方 model list 確認）
GEMINI_LIVE_MODEL=models/gemini-3.1-flash-live-preview
GEMINI_CLEANUP_MODEL=gemini-3.1-flash-lite

# 後端
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# CORS：只允許自己的前端 domain（逗號分隔）
ALLOWED_ORIGINS=https://your-frontend-domain.example

# 開發：true 時用假 transcript / 假 cleanup，不呼叫 Gemini（省 API）
MOCK_MODE=false

# Ephemeral token 有效期（秒）
LIVE_TOKEN_TTL=600

# SenseVoice v2 WebSocket 短效簽名 token（後端 HMAC-SHA256 簽發、SenseVoice 驗證）。
# 後端與 SenseVoice 容器必須共用「同一個」secret（兩個 Docker context 各自讀 env，
# 不互相 import）。假值範本；真值只放 .env / SenseVoice 執行環境，切勿提交。
# 產生方法（示例）：python -c "import secrets; print(secrets.token_urlsafe(48))"
SENSEVOICE_WS_TOKEN_SECRET=replace_with_a_long_random_shared_secret
# Token TTL（秒），有界 5–300，預設 60。
SENSEVOICE_WS_TOKEN_TTL=60

# SenseVoice container host mapping；local POC 預設 7860，migration 可設為 8082。
SENSEVOICE_HOST_PORT=7860
