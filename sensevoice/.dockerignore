# Docker ignore for sensevoice/ build context
# Keep: source, requirements, checksum, tests
# Exclude: venv, caches, generated files, local traces

# Python venv
venv/
.venv/

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Distribution / packaging
build/
dist/
*.egg-info/

# Test + coverage artefacts
.pytest_cache/
.coverage
htmlcov/
*.xml

# Local trace / debug output (SENSEVOICE_DEBUG_TRACE=1)
/tmp/
sv-debug/

# Loose model blobs / caches — must NEVER enter the build context.
# Models are fetched/preloaded INSIDE the build (fetch_models.py + FunASR
# preload) and baked into image layers; any stray weights in the context would
# bloat the upload and could shadow the reproducible in-build download.
# HuggingFace / FunASR / ModelScope caches:
hub/
.cache/
huggingface/
funasr/
modelscope/
models/
# Raw weight / checkpoint blobs by extension:
*.onnx
*.pt
*.pth
*.bin
*.mvn
*.model
*.ckpt
*.safetensors

# OS / editor noise
.DS_Store
*.swp
*.swo
*~
.idea/
.vscode/

# The Dockerfile itself isn't needed inside the build context at runtime
# (it's used by the builder, not COPY-ed in), but we do NOT exclude it here
# because Docker removes it from the context automatically; explicit exclusion
# is harmless but unnecessary.

# Do NOT exclude: api.py, fetch_models.py, models.sha256, funasr_models.sha256,
# verify_funasr_cache.py, model_pins.py, requirements.txt, tests/, Dockerfile,
# README.md, DEPLOY.md
# (These are source/manifests, not blobs — the *.pt / *.onnx / *.mvn globs above
#  match weight files only, never model_pins.py or models.sha256.)
